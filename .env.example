# Local development only (used by `vercel dev`).
# In production, set these in the Vercel dashboard:
#   Project → Settings → Environment Variables (Production / Preview / Development).
# Never commit a real .env file.

# Required: Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Optional: override the default Claude model
ANTHROPIC_MODEL=claude-haiku-4-5
